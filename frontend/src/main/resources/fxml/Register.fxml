<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.campus.frontend.controller.RegisterController">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0"/>
    </padding>

    <Label text="Create an Account" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Label>

    <TextField fx:id="fullNameField" promptText="Full Name" prefHeight="35.0"/>
    <TextField fx:id="emailField" promptText="College Email" prefHeight="35.0"/>
    <PasswordField fx:id="passwordField" promptText="Password (min 6 chars)" prefHeight="35.0"/>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="I want to be a: "/>
        <ComboBox fx:id="roleComboBox" prefWidth="150.0"/>
    </HBox>

    <Button text="Register" onAction="#onRegister" prefWidth="200.0" prefHeight="35.0"
            style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true"/>

    <HBox alignment="CENTER" spacing="5.0">
        <Label text="Already have an account?"/>
        <Hyperlink text="Login here" onAction="#onGoToLogin"/>
    </HBox>
</VBox>
