<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.campus.frontend.controller.ProfileController">
    <padding><Insets top="20" left="30" right="30" bottom="20"/></padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="My Profile" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Back" onAction="#onBack"/>
    </HBox>

    <Label fx:id="userInfoLabel" style="-fx-text-fill: #555;"/>

    <VBox spacing="8" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 8;">
        <Label text="Wallet Payment Modes" style="-fx-font-weight: bold;"/>
        <HBox spacing="10">
            <CheckBox fx:id="walletModeCheck" text="CAMPUS Wallet"/>
            <CheckBox fx:id="gpayModeCheck" text="Google Pay"/>
            <CheckBox fx:id="cardModeCheck" text="Card"/>
            <CheckBox fx:id="cashModeCheck" text="Cash"/>
            <CheckBox fx:id="netBankModeCheck" text="Net Banking"/>
            <Button text="Save Modes" onAction="#onSaveWalletModes"/>
        </HBox>
    </VBox>

    <!-- Money summary cards -->
    <HBox spacing="20">
        <VBox style="-fx-background-color: #ebf5fb; -fx-padding: 15; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label text="Wallet Balance" style="-fx-font-weight: bold; -fx-text-fill: #154360;"/>
            <Label fx:id="balanceLabel" style="-fx-font-size: 22; -fx-text-fill: #2980b9;"/>
        </VBox>
        <VBox style="-fx-background-color: #eafaf1; -fx-padding: 15; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label text="Total Earned" style="-fx-font-weight: bold; -fx-text-fill: #1a7a4a;"/>
            <Label fx:id="earningsLabel" style="-fx-font-size: 22; -fx-text-fill: #27ae60;"/>
        </VBox>
        <VBox style="-fx-background-color: #fef9e7; -fx-padding: 15; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label text="Total Spent" style="-fx-font-weight: bold; -fx-text-fill: #7d6608;"/>
            <Label fx:id="spendingLabel" style="-fx-font-size: 22; -fx-text-fill: #f39c12;"/>
        </VBox>
    </HBox>
    
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #f4f6f7; -fx-padding: 10; -fx-background-radius: 8;">
        <Label text="Recharge Wallet:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="topUpAmountField" promptText="Amount (₹)" prefWidth="120"/>
        <Button text="Add Funds" onAction="#onTopUpWallet" 
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE">

        <Tab text="Purchases (Buying)">
            <VBox spacing="8">
                <padding><Insets top="10"/></padding>
                <ListView fx:id="spendingListView" prefHeight="200"/>
                <HBox spacing="10">
                    <TextField fx:id="confirmTxIdField" promptText="Transaction ID" prefWidth="140"/>
                    <Button text="Confirm Delivery" onAction="#onConfirmDelivery"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                    <TextField fx:id="disputeReasonField" promptText="Dispute reason" HBox.hgrow="ALWAYS"/>
                    <Button text="Open Dispute" onAction="#onOpenDispute"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Sales (Selling)">
            <VBox spacing="8">
                <padding><Insets top="10"/></padding>
                <Label text="Your sales transactions. Copy a TX# and mark it shipped once you've sent the item."
                    style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;" wrapText="true"/>
                <ListView fx:id="earningsListView" prefHeight="180"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Transaction ID:"/>
                    <TextField fx:id="sellerTxIdField" promptText="TX ID" prefWidth="100"/>
                    <Button text="Mark as Shipped" onAction="#onMarkShipped"
                            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
                <Label text="After you mark as shipped, the buyer confirms delivery, then funds are released to you."
                    style="-fx-text-fill: #95a5a6; -fx-font-size: 11;" wrapText="true"/>
            </VBox>
        </Tab>
    </TabPane>
    <Separator/>
    <VBox spacing="8" style="-fx-background-color: #fef9e7; -fx-padding: 12; -fx-background-radius: 8;">
        <Label text="Seller Access" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
        <Label text="Want to list items for auction? Request seller access — an admin will review and approve your account."
            wrapText="true" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
        <Button text="Request Seller Access" onAction="#onRequestSellerAccess"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </VBox>
    <Label fx:id="actionStatusLabel" wrapText="true"/>
</VBox>
