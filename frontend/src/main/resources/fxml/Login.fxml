<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.campus.frontend.controller.LoginController">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0"/>
    </padding>

    <Label text="CAMPUS Login" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
    </Label>

    <Label text="Welcome back to the college marketplace" textFill="#7f8c8d">
        <font>
            <Font size="14.0"/>
        </font>
    </Label>

    <TextField fx:id="emailField" promptText="Email Address" prefHeight="35.0"/>
    <PasswordField fx:id="passwordField" promptText="Password" prefHeight="35.0"/>

    <Button text="Login" onAction="#onLogin" prefWidth="200.0" prefHeight="35.0"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true"/>

    <HBox alignment="CENTER" spacing="5.0">
        <Label text="Don't have an account?"/>
        <Hyperlink text="Sign up here" onAction="#onGoToRegister"/>
    </HBox>
</VBox>
